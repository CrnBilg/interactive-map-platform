PORT=5000
MONGO_URI=mongodb://localhost:27017/citylore
JWT_SECRET=citylore_super_secret_key_change_in_production
CLIENT_URL=http://localhost:5173
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Optional. Map shortest driving/walking routes via OpenRouteService (fallback: public OSRM).
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# Optional chatbot support. Use an OpenRouter key here, never in frontend/.env.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
